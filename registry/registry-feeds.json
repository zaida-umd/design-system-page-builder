{
  "_meta": {
    "version": "1.0.0",
    "components_version": "1.18.2",
    "source_package": "@universityofmaryland/web-components-library",
    "last_verified": "2026-04-24",
    "cdn_base": "https://unpkg.com/@universityofmaryland/web-components-library@1.18.2/dist",
    "notes": "Verified from design-system submodule source. All feed components are data-driven (no slots) and require a `data-token` to fetch from the UMD feeds API.",
    "category": "feeds",
    "components": [
      "feed-events",
      "feed-events-list",
      "feed-events-grouped",
      "feed-news",
      "feed-news-grid",
      "feed-news-list",
      "feed-news-featured",
      "feed-experts-grid",
      "feed-experts-list",
      "feed-expert-bio",
      "feed-expert-in-the-news",
      "feed-in-the-news-grid",
      "feed-in-the-news-list"
    ],
    "shared_behavior": "All feed components self-populate from the UMD feeds API. None accept slots. All require a valid `data-token`. Grid components support `data-layout-column-count` (1\u20134) and `data-layout-row-count`; lists support only row count."
  },
  "feed-events": {
    "tag": "umd-feed-events",
    "label": "Events Grid Feed",
    "description": "Dynamic grid of event cards fetched from the events API. Responsive columns, supports lazy loading.",
    "slots": [],
    "attrs": [
      {"name": "data-token", "type": "string", "required": true, "description": "API authentication token."},
      {"name": "data-filter-group-ids", "type": "string", "description": "Comma-separated category IDs."},
      {"name": "data-layout-column-count", "type": "number", "description": "1\u20134. Default: 3."},
      {"name": "data-layout-row-count", "type": "number", "description": "1\u20132. Default: 1."},
      {"name": "data-theme", "type": "enum", "values": ["dark"]},
      {"name": "data-visual-transparent", "type": "boolean"},
      {"name": "data-lazy-load", "type": "boolean"}
    ],
    "configurable": true,
    "page_types": ["landing", "interior"],
    "source": "npm",
    "priority": 2
  },
  "feed-events-list": {
    "tag": "umd-feed-events-list",
    "label": "Events List Feed",
    "description": "Dynamic stacked list of event cards from the events API.",
    "slots": [],
    "attrs": [
      {"name": "data-token", "type": "string", "required": true},
      {"name": "data-filter-group-ids", "type": "string"},
      {"name": "data-layout-row-count", "type": "number"},
      {"name": "data-theme", "type": "enum", "values": ["dark"]},
      {"name": "data-lazy-load", "type": "boolean"}
    ],
    "configurable": true,
    "page_types": ["landing", "interior"],
    "source": "npm",
    "priority": 2
  },
  "feed-events-grouped": {
    "tag": "umd-feed-events-grouped",
    "label": "Events Grouped Feed",
    "description": "Events list grouped by date. Lazy loading is always on.",
    "slots": [],
    "attrs": [
      {"name": "data-token", "type": "string", "required": true},
      {"name": "data-theme", "type": "enum", "values": ["dark"]},
      {"name": "data-layout-row-count", "type": "number", "description": "Default: 10."}
    ],
    "configurable": true,
    "page_types": ["landing", "interior"],
    "source": "npm",
    "priority": 3
  },
  "feed-news": {
    "tag": "umd-feed-news",
